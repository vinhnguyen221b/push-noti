# ─────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Static API key that inbound callers must send as the `x-api-key` header.
# Generate a strong value, e.g. `openssl rand -hex 32`
SERVER_API_KEY=replace-with-a-strong-random-string

# ─────────────────────────────────────────────────────────────────────────
# Firebase service account credential.
# Provide EXACTLY ONE of the following two forms.
# If BOTH are set, the BASE64 form takes precedence.
# ─────────────────────────────────────────────────────────────────────────
# (a) Path to a JSON file on disk (local dev convenience):
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# (b) Base64-encoded JSON contents (preferred for deployment):
#     macOS/Linux:  base64 -i ./secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ─────────────────────────────────────────────────────────────────────────
# Rate limiting (per client IP)
# ─────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ─────────────────────────────────────────────────────────────────────────
# Reverse proxy
# Set to the number of trusted proxy hops (e.g. 1) or `true` when running
# behind a reverse proxy / load balancer, so express-rate-limit sees the real
# client IP. Leave as `false` (or unset) when the server is exposed directly.
# On Render, set this to 1.
# ─────────────────────────────────────────────────────────────────────────
TRUST_PROXY=false

# ─────────────────────────────────────────────────────────────────────────
# Admin UI
# Serve the browser UI at / for manually triggering notifications.
# Set to false for a headless, API-only deployment.
# ─────────────────────────────────────────────────────────────────────────
ENABLE_UI=true
