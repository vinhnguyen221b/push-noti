{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm init *)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(npm ci)",
      "Bash(npm uninstall *)",
      "Bash(npm list *)",
      "Bash(npm ls *)",
      "Bash(npm outdated)",
      "Bash(npm audit)",
      "Bash(npm audit fix)",

      "Bash(npm run build)",
      "Bash(npm run build *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run format)",
      "Bash(npm run format *)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run test)",
      "Bash(npm run test *)",
      "Bash(npm run dev)",
      "Bash(npm run start)",
      "Bash(npm start)",

      "Bash(npx tsc)",
      "Bash(npx tsc *)",
      "Bash(npx tsx *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx vitest)",
      "Bash(npx vitest *)",

      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",

      "Bash(mkdir *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(rg *)",

      "Bash(cat package.json)",
      "Bash(cat tsconfig.json)",
      "Bash(cat .env.example)",
      "Bash(cat .gitignore)",
      "Bash(cat .eslintrc.cjs)",
      "Bash(cat .prettierrc)",
      "Bash(cat README.md)",

      "Bash(curl http://localhost:*)",
      "Bash(curl -X * http://localhost:*)",
      "Bash(curl -i http://localhost:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -v http://localhost:*)",
      "Bash(curl --max-time * http://localhost:*)",

      "Bash(kill *)",
      "Bash(pkill -f node)",
      "Bash(pkill -f tsx)",
      "Bash(lsof -i *)",

      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git init)"
    ],
    "deny": [
      "Read(./secrets/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/firebase-service-account*.json)",
      "Read(**/*-service-account*.json)",
      "Read(**/google-services.json)",
      "Read(**/GoogleService-Info.plist)",

      "Write(./secrets/**)",
      "Edit(./secrets/**)",
      "Write(./.env)",
      "Edit(./.env)",
      "Write(**/firebase-service-account*.json)",
      "Edit(**/firebase-service-account*.json)",

      "Bash(cat ./.env)",
      "Bash(cat ./.env.*)",
      "Bash(cat ./secrets/*)",
      "Bash(cat ./secrets/**)",
      "Bash(echo * > ./.env)",
      "Bash(echo * >> ./.env)",

      "Bash(curl * fcm.googleapis.com *)",
      "Bash(curl * https://fcm.googleapis.com *)",
      "Bash(curl * googleapis.com *)",
      "Bash(curl * https://googleapis.com *)",
      "Bash(curl * firebase.google.com *)",
      "Bash(curl * https://firebase.google.com *)",

      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ..*)",
      "Bash(rm -rf /etc/*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",

      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean -fd *)",

      "Bash(npm publish)",
      "Bash(npm publish *)",
      "Bash(npm login)",
      "Bash(npm adduser)"
    ],
    "ask": [
      "Bash(curl https://*)",
      "Bash(curl http://*)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(mv ../*)",
      "Bash(cp ../*)",
      "WebFetch",
      "WebSearch"
    ],
    "additionalDirectories": []
  }
}